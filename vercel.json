{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "buildCommand": "npx vite build",
    "outputDirectory": "dist/public",
    "framework": null,
    "functions": {
        "api/trpc/[trpc].ts": {
            "includeFiles": "server/**"
        }
    },
    "routes": [
        {
            "handle": "filesystem"
        },
        {
            "src": "/api/trpc/(.*)",
            "dest": "/api/trpc/[trpc]"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}