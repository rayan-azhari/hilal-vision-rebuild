{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "buildCommand": "npx vite build",
    "outputDirectory": "dist/public",
    "framework": null,
    "functions": {
        "api/trpc/[trpc].ts": {
            "includeFiles": "server/**"
        }
    },
    "rewrites": [
        {
            "source": "/api/og",
            "destination": "/api/og"
        },
        {
            "source": "/api/trpc/:path*",
            "destination": "/api/trpc/[trpc]"
        },
        {
            "source": "/((?!.*\\.).*)",
            "destination": "/index.html"
        }
    ]
}